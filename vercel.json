{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/", "dest": "/html/index.html" },
    { "src": "/surf", "dest": "/html/surf.html" },
    { "src": "/sup", "dest": "/html/sup.html" },
    { "src": "/kano", "dest": "/html/kano.html" },
    { "src": "/rezervasyon", "dest": "/html/rezervasyon.html" },
    { "src": "/galeri", "dest": "/html/galeri.html" },
    { "src": "/hakkimizda", "dest": "/html/hakkimizda.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
